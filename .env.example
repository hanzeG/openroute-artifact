# XRPL endpoints (copy to .env and edit if needed)

XRPL_RIPPLE_S1_RPC=https://s1.ripple.com:51234/
XRPL_RIPPLE_S2_RPC=https://s2.ripple.com:51234/
XRPL_CLUSTER_RPC=https://xrplcluster.com/

# Optional local-only endpoints for long fetches. Do not commit private URLs.
# XRPL_EXTRA_RPC_1=
# XRPL_EXTRA_RPC_2=
# XRPL_EXTRA_RPC_3=

# Concurrent fetch settings. Tune down if a public endpoint rate-limits.
XRPL_FETCH_WORKERS=8
XRPL_PREBOOK_WORKERS=8
XRPL_EXTRA_WORKERS=8
